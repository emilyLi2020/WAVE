# Copy to client/.env.local and fill in. Do NOT commit your filled copy.

# ---------------------------------------------------------------------------
# Training UI gate. When this is anything other than the literal string
# "true", every route under /training and /api/training returns 404. This
# is the one knob to remove the UI before deploying the demo to judges.
# ---------------------------------------------------------------------------
NEXT_PUBLIC_TRAINING_ENABLED=true

# ---------------------------------------------------------------------------
# Optional. Override where the /training UI writes its JSON files.
# Defaults to <repo-root>/data/training-seeds/ (i.e. ../data/training-seeds
# relative to the client/ working directory). Set this if you run the dev
# server from somewhere other than client/.
# ---------------------------------------------------------------------------
# WAVE_TRAINING_DATA_DIR=/absolute/path/to/data/training-seeds
